function Initialize-SwaswaSshHost {
    [CmdletBinding()]
    param(
        [switch]$InspectOnly
    )

    Set-StrictMode -Version Latest
    $ErrorActionPreference = "Stop"

    function Write-Step {
        param([string]$Message)
        Write-Host "`n==> $Message" -ForegroundColor Cyan
    }

    function Test-IsAdministrator {
        $identity = [Security.Principal.WindowsIdentity]::GetCurrent()
        $principal = [Security.Principal.WindowsPrincipal]::new($identity)

        return $principal.IsInRole(
            [Security.Principal.WindowsBuiltInRole]::Administrator
        )
    }

    $isAdministrator = Test-IsAdministrator

    if (-not $InspectOnly -and -not $isAdministrator) {
        throw @"
Administrator access is required.

Close this window, open PowerShell using:
    Run as administrator

Then paste and run the script again.
"@
    }

    Write-Step "Reading computer information"

    $computerName = $env:COMPUTERNAME
    $currentUser = "$env:USERDOMAIN\$env:USERNAME"

    $operatingSystem = Get-CimInstance Win32_OperatingSystem
    $computerSystem = Get-CimInstance Win32_ComputerSystem

    $memoryGiB = [math]::Round(
        [double]$computerSystem.TotalPhysicalMemory / 1GB,
        1
    )

    Write-Step "Checking network profiles"

    $networkProfiles = @(
        Get-NetConnectionProfile -ErrorAction SilentlyContinue |
            Select-Object InterfaceAlias, Name, NetworkCategory, IPv4Connectivity
    )

    $activeAdapters = @(
        Get-NetAdapter |
            Where-Object Status -eq "Up"
    )

    $adapterIndexes = @(
        $activeAdapters | Select-Object -ExpandProperty InterfaceIndex
    )

    $addresses = @(
        Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
            Where-Object {
                $_.InterfaceIndex -in $adapterIndexes -and
                $_.IPAddress -notlike "127.*" -and
                $_.IPAddress -notlike "169.254.*"
            } |
            Select-Object InterfaceAlias, IPAddress, PrefixLength
    )

    if (-not $InspectOnly) {
        Write-Step "Checking OpenSSH Server installation"

        $capability = Get-WindowsCapability `
            -Online `
            -Name "OpenSSH.Server~~~~0.0.1.0"

        if ($capability.State -ne "Installed") {
            Write-Host "Installing OpenSSH Server..." -ForegroundColor Yellow

            $installation = Add-WindowsCapability `
                -Online `
                -Name "OpenSSH.Server~~~~0.0.1.0"

            if ($installation.RestartNeeded) {
                Write-Warning "Windows reports that a restart is required."
            }
        }
        else {
            Write-Host "OpenSSH Server is already installed." -ForegroundColor Green
        }

        Write-Step "Configuring the SSH service"

        Set-Service -Name sshd -StartupType Automatic

        $sshService = Get-Service -Name sshd

        if ($sshService.Status -ne "Running") {
            Start-Service -Name sshd
        }

        Write-Step "Configuring the Windows Firewall"

        $firewallRule = Get-NetFirewallRule `
            -Name "OpenSSH-Server-In-TCP" `
            -ErrorAction SilentlyContinue

        if ($null -eq $firewallRule) {
            New-NetFirewallRule `
                -Name "OpenSSH-Server-In-TCP" `
                -DisplayName "OpenSSH Server (sshd)" `
                -Enabled True `
                -Direction Inbound `
                -Protocol TCP `
                -Action Allow `
                -LocalPort 22 `
                -Profile Private,Domain | Out-Null

            Write-Host "Created the SSH firewall rule." -ForegroundColor Green
        }
        else {
            Enable-NetFirewallRule `
                -Name "OpenSSH-Server-In-TCP"

            Set-NetFirewallRule `
                -Name "OpenSSH-Server-In-TCP" `
                -Profile Private,Domain

            Write-Host "Verified the existing SSH firewall rule." -ForegroundColor Green
        }
    }

    Write-Step "Collecting final SSH status"

    $capability = Get-WindowsCapability `
        -Online `
        -Name "OpenSSH.Server~~~~0.0.1.0" `
        -ErrorAction SilentlyContinue

    $sshService = Get-Service `
        -Name sshd `
        -ErrorAction SilentlyContinue

    $firewallRule = Get-NetFirewallRule `
        -Name "OpenSSH-Server-In-TCP" `
        -ErrorAction SilentlyContinue

    $portListening = $false

    if ($null -ne $sshService -and $sshService.Status -eq "Running") {
        Start-Sleep -Seconds 1

        $portListening = Test-NetConnection `
            -ComputerName 127.0.0.1 `
            -Port 22 `
            -InformationLevel Quiet `
            -WarningAction SilentlyContinue
    }

    Write-Step "Checking WSL"

    $wslDistributions = @()

    if (Get-Command wsl.exe -ErrorAction SilentlyContinue) {
        $wslDistributions = @(
            wsl.exe --list --quiet 2>$null |
                ForEach-Object {
                    "$_".Replace([char]0, "").Trim()
                } |
                Where-Object { $_ }
        )
    }

    Write-Step "Checking local storage"

    $drives = @(
        Get-PSDrive -PSProvider FileSystem |
            Where-Object { $null -ne $_.Used } |
            ForEach-Object {
                [pscustomobject]@{
                    Drive    = $_.Name
                    Root     = $_.Root
                    UsedGiB  = [math]::Round($_.Used / 1GB, 1)
                    FreeGiB  = [math]::Round($_.Free / 1GB, 1)
                    TotalGiB = [math]::Round(
                        ($_.Used + $_.Free) / 1GB,
                        1
                    )
                }
            }
    )

    Write-Step "Swaswa SSH host report"

    $report = [ordered]@{
        ComputerName = $computerName
        CurrentUser = $currentUser
        IsAdministrator = $isAdministrator
        Windows = $operatingSystem.Caption
        WindowsVersion = $operatingSystem.Version
        MemoryGiB = $memoryGiB
        OpenSshState = $capability.State
        SshServiceStatus = if ($sshService) {
            "$($sshService.Status)"
        }
        else {
            "Missing"
        }
        SshStartupType = if ($sshService) {
            "$($sshService.StartType)"
        }
        else {
            "Missing"
        }
        FirewallEnabled = if ($firewallRule) {
            $firewallRule.Enabled
        }
        else {
            $false
        }
        FirewallProfiles = if ($firewallRule) {
            "$($firewallRule.Profile)"
        }
        else {
            "Missing"
        }
        Port22Listening = $portListening
        NetworkProfiles = $networkProfiles
        IPv4Addresses = $addresses
        WslDistributions = $wslDistributions
        Drives = $drives
    }

    $report | ConvertTo-Json -Depth 6

    Write-Step "Connection commands"

    if ($addresses.Count -eq 0) {
        Write-Warning "No usable LAN IPv4 address was detected."
    }
    else {
        foreach ($address in $addresses) {
            Write-Host (
                "ssh {0}@{1}" -f $env:USERNAME, $address.IPAddress
            ) -ForegroundColor Green
        }
    }

    $publicProfiles = @(
        $networkProfiles |
            Where-Object NetworkCategory -eq "Public"
    )

    if ($publicProfiles.Count -gt 0) {
        Write-Warning @"
One or more active networks are classified as Public.
The SSH firewall rule intentionally allows only Private or Domain networks.

If this is your trusted home network, review it before changing its category:
    Get-NetConnectionProfile
"@
    }

    if ($portListening) {
        Write-Host "`nSSH is installed and listening locally." `
            -ForegroundColor Green
    }
    else {
        Write-Warning "SSH is not currently listening on port 22."
    }
}

Initialize-SwaswaSshHost
